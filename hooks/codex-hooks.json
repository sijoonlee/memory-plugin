{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_UV_BIN}\" --directory \"${CODEX_PLUGIN_ROOT}\" run memory-mcp-event append --quiet --root \"${CODEX_PLUGIN_ROOT}/.memory-mcp\" --adapter codex --event-type user_prompt",
            "statusMessage": "Recording Memory MCP prompt event"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_UV_BIN}\" --directory \"${CODEX_PLUGIN_ROOT}\" run memory-mcp-event append --quiet --root \"${CODEX_PLUGIN_ROOT}/.memory-mcp\" --adapter codex --event-type tool_result",
            "statusMessage": "Recording Memory MCP tool event"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_UV_BIN}\" --directory \"${CODEX_PLUGIN_ROOT}\" run memory-mcp-event append --quiet --root \"${CODEX_PLUGIN_ROOT}/.memory-mcp\" --adapter codex --event-type turn_stop",
            "statusMessage": "Recording Memory MCP turn stop"
          }
        ]
      }
    ]
  }
}
